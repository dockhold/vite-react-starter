# Vite inlines VITE_-prefixed variables at BUILD time and ships them to the
# browser. Set these in the Dockhold dashboard BEFORE deploying so they're
# present when `vite build` runs.
#
# Never put secrets behind the VITE_ prefix — anything with it is public.
# PORT is provided by Dockhold at runtime; the start script reads it.
VITE_API_URL=https://your-api.dockhold.app
