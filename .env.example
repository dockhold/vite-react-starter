# Vite inlines VITE_-prefixed variables into the bundle at BUILD time. To ship
# them, copy this file to a committed `.env.production` — Vite reads it when the
# Dockerfile runs `npm run build`.
#
# These values are PUBLIC: anything with the VITE_ prefix is baked into the
# bundle and visible to every visitor. Never put secrets here. Dashboard
# variables are runtime-only and can't reach a pre-built static bundle.
VITE_API_URL=https://your-api.dockhold.app
